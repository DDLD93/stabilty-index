# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/stability_index"

# NextAuth.js — required for /api/auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: public site URL (defaults to production URL)
# NEXT_PUBLIC_SITE_URL="https://www.nigeriastabilityIndex.ng"

# Optional: seed admin (used by `npm run db:seed`; change in production)
# SEED_ADMIN_EMAIL="admin@NigeriaStabilityIndex.org"
# SEED_ADMIN_PASSWORD="admin-change-me"

# Contact form (SMTP via Nodemailer) — required for POST /api/public/contact
# SMTP_PORT: typically 587 (STARTTLS, set SMTP_SECURE=false) or 465 (SSL, set SMTP_SECURE=true)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"
# SMTP_SECURE="true"
CONTACT_MAIL_FROM="noreply@example.com"
CONTACT_MAIL_TO="inbox@example.com"
